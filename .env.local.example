# AiExponent Web — Environment Variables
# Copy to .env.local and fill in values

# ── Required ──
RESEND_API_KEY=re_...                       # Transactional email (contact form)
GITHUB_TOKEN=ghp_...                        # GitHub API (elevated rate limits)

# ── Analytics ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=aiexponent.com
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# ── Email ──
RESEND_NOTIFY_TO=hello@aiexponent.com

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://aiexponent.com
